{%- comment -%}
  Usage: {% render 'product-card', product: product, badge: 'New' %}
{%- endcomment -%}

{%- assign back_image = nil -%}
{%- for img in product.images -%}
  {%- if img.id != product.featured_image.id -%}
    {%- assign back_image = img -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

<article class="product-card{% if back_image %} product-card--has-back{% endif %}">
  <a href="{{ product.url }}">
    <div class="product-card__media">
      {%- if badge != blank -%}
        <span class="product-card__badge">{{ badge }}</span>
      {%- elsif product.tags contains 'new' -%}
        <span class="product-card__badge">New</span>
      {%- endif -%}

      {%- if product.featured_image -%}
        <img
          class="product-card__img product-card__img--front"
          src="{{ product.featured_image | image_url: width: 600 }}"
          srcset="{{ product.featured_image | image_url: width: 300 }} 300w,
                  {{ product.featured_image | image_url: width: 600 }} 600w,
                  {{ product.featured_image | image_url: width: 900 }} 900w"
          sizes="(min-width: 990px) 25vw, 50vw"
          alt="{{ product.featured_image.alt | escape }}"
          loading="lazy"
          width="600" height="750">
        {%- if back_image -%}
          <img
            class="product-card__img product-card__img--back"
            src="{{ back_image | image_url: width: 600 }}"
            srcset="{{ back_image | image_url: width: 300 }} 300w,
                    {{ back_image | image_url: width: 600 }} 600w,
                    {{ back_image | image_url: width: 900 }} 900w"
            sizes="(min-width: 990px) 25vw, 50vw"
            alt="{{ back_image.alt | escape }}"
            loading="lazy"
            aria-hidden="true"
            width="600" height="750">
        {%- endif -%}
      {%- else -%}
        <svg viewBox="0 0 4 5" preserveAspectRatio="none" width="100%" height="100%">
          <rect width="4" height="5" fill="#f4ead5"/>
          <text x="2" y="2.8" font-family="Anton" font-size="0.55" fill="#e8552c" text-anchor="middle">{{ product.title | upcase | truncate: 12, '' }}</text>
        </svg>
      {%- endif -%}
    </div>

    <div class="product-card__body">
      <h3 class="product-card__title">{{ product.title }}</h3>
      {% render 'price', product: product %}

      {%- assign color_option = nil -%}
      {%- for option in product.options_with_values -%}
        {%- assign opt_name = option.name | downcase -%}
        {%- if opt_name contains 'color' or opt_name contains 'colour' -%}
          {%- assign color_option = option -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if color_option -%}
        <div class="product-card__swatches">
          {%- for value in color_option.values limit: 5 -%}
            <span class="swatch" style="background: {{ value | handle }};" title="{{ value }}"></span>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </a>
</article>
