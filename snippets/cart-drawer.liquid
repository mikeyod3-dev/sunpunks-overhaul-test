{%- comment -%}
  Cart drawer — body content is hydrated client-side from localStorage by theme.js.
  When real Shopify cart state is available, theme.js's Cart object falls back to
  rendering server-side cart items if needed.
{%- endcomment -%}

<div class="drawer-backdrop" data-drawer-backdrop></div>
<aside class="drawer" aria-label="Cart" aria-hidden="true" data-drawer>
  <header class="drawer__head">
    <h3 style="font-size:1.4rem;">{{ 'cart.general.title' | t }}</h3>
    <button class="icon-btn" aria-label="Close cart" data-drawer-close>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 6 12 12M6 18 18 6"/></svg>
    </button>
  </header>
  <div class="drawer__body">
    {%- if cart.item_count > 0 -%}
      {%- for item in cart.items -%}
        <div class="cart-item">
          <div class="cart-item__img">
            {%- if item.image -%}<img src="{{ item.image | image_url: width: 120 }}" alt="" width="96" height="96">{%- endif -%}
          </div>
          <div>
            <strong>{{ item.product.title }}</strong>
            <div class="muted" style="font-size:.85rem;">{{ item.variant.title }} · Qty {{ item.quantity }}</div>
          </div>
          <span>{{ item.final_line_price | money }}</span>
        </div>
      {%- endfor -%}
    {%- else -%}
      <p class="muted" style="text-align:center; padding:2rem 1rem;">Your cart is empty.<br/>Pick a fit from the <a href="{{ routes.all_products_collection_url }}">Collection</a>.</p>
    {%- endif -%}
  </div>
  <div class="drawer__foot">
    <div style="display:flex; justify-content:space-between; margin-bottom: .75rem;">
      <strong>{{ 'cart.general.subtotal' | t }}</strong><strong>{{ cart.total_price | money }}</strong>
    </div>
    <a href="{{ routes.cart_url }}" class="btn btn--ghost btn--block" style="margin-bottom:.5rem;">View cart</a>
    <a href="{{ routes.cart_url }}" class="btn btn--primary btn--block">{{ 'cart.general.checkout' | t }}</a>
  </div>
</aside>
