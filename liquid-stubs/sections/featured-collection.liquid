{% comment %}
  Section: featured-collection
  Drop-in for the homepage "heat rack". Merchandisable from the theme editor.
{% endcomment %}

<section class="section" id="shopify-section-{{ section.id }}">
  <div class="container">
    <header class="section-head">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="h2">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.link_url != blank -%}
        <a class="section-head__link" href="{{ section.settings.link_url }}">
          {{ section.settings.link_text | default: 'Shop all' }}
        </a>
      {%- endif -%}
    </header>

    {%- assign coll = collections[section.settings.collection] -%}
    <div class="grid grid--products">
      {%- for product in coll.products limit: section.settings.limit -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        <p class="muted">No products yet — pick a collection in the theme editor.</p>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "section--featured",
  "settings": [
    { "type": "text",       "id": "eyebrow",  "label": "Eyebrow",  "default": "Best sellers" },
    { "type": "text",       "id": "heading",  "label": "Heading",  "default": "The heat rack" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range",      "id": "limit",    "label": "Products to show", "min": 4, "max": 16, "step": 1, "default": 8 },
    { "type": "url",        "id": "link_url", "label": "View-all link" },
    { "type": "text",       "id": "link_text","label": "View-all text", "default": "Shop all" }
  ],
  "presets": [ { "name": "Featured collection" } ]
}
{% endschema %}
