<section class="collection-hero" id="shopify-section-{{ section.id }}">
  <div class="container" data-anim>
    <p class="eyebrow">Collection</p>
    <h1 class="h1">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="lede" style="margin-top:1rem;">{{ collection.description }}</p>
    {%- endif -%}
  </div>
</section>

<section class="section section--tight">
  <div class="container">
    <div class="collection-toolbar">
      <div class="cluster">
        <strong>{{ collection.products_count }} products</strong>
        <span class="muted">·</span>
        <span class="muted">Showing {{ paginate.current_offset | plus: 1 }}–{{ paginate.current_offset | plus: collection.products.size }}</span>
      </div>
      <div class="cluster">
        <label for="sort" class="muted" style="margin-right:.5rem;">Sort</label>
        <select id="sort" name="sort_by" aria-label="Sort by" onchange="window.location.href = `${window.location.pathname}?sort_by=${this.value}`;">
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>{{ option.name }}</option>
          {%- endfor -%}
        </select>
      </div>
    </div>

    <div class="grid grid--products" data-anim-stagger>
      {%- paginate collection.products by 16 -%}
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- else -%}
          <p class="muted" style="grid-column: 1 / -1;">No products in this collection yet.</p>
        {%- endfor -%}
      {%- endpaginate -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="cluster" style="justify-content:center; margin-top: 3rem;" aria-label="Pagination">
        {%- if paginate.previous -%}<a class="btn btn--ghost btn--sm" href="{{ paginate.previous.url }}">← Prev</a>{%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a class="btn btn--ghost btn--sm" href="{{ part.url }}">{{ part.title }}</a>
          {%- else -%}
            <a class="btn btn--ghost btn--sm" aria-current="page">{{ part.title }}</a>
          {%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}<a class="btn btn--ghost btn--sm" href="{{ paginate.next.url }}">Next →</a>{%- endif -%}
      </nav>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection — main",
  "tag": "section",
  "settings": []
}
{% endschema %}
