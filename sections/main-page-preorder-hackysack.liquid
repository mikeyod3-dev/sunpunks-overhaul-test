{%- assign max_8    = section.settings.max_8panel    | default: 45 -%}
{%- assign max_32   = section.settings.max_32panel   | default: 45 -%}
{%- assign taken_8  = section.settings.taken_8panel  | default: 0  -%}
{%- assign taken_32 = section.settings.taken_32panel | default: 0  -%}

{%- assign left_8  = max_8  | minus: taken_8  -%}
{%- assign left_32 = max_32 | minus: taken_32 -%}
{%- if left_8  < 0 -%}{%- assign left_8  = 0 -%}{%- endif -%}
{%- if left_32 < 0 -%}{%- assign left_32 = 0 -%}{%- endif -%}

{%- assign sold_8  = false -%}{%- if left_8  <= 0 -%}{%- assign sold_8  = true -%}{%- endif -%}
{%- assign sold_32 = false -%}{%- if left_32 <= 0 -%}{%- assign sold_32 = true -%}{%- endif -%}
{%- assign sold_out = false -%}{%- if sold_8 and sold_32 -%}{%- assign sold_out = true -%}{%- endif -%}

<section class="preorder-page"
         id="preorder-section"
         data-price="{{ section.settings.price }}"
         data-left-8="{{ left_8 }}"
         data-left-32="{{ left_32 }}"
         data-worker-url="{{ section.settings.worker_url }}"
         style="background: linear-gradient(180deg, #f9d9bf 0%, var(--sand) 100%); padding: 4rem 0 5rem; min-height: 80vh;">
  <div class="container" style="max-width: 620px;">

    <div style="text-align:center;" data-anim>
      <span class="coming-stamp">
        {%- if sold_out -%}Sold out{%- else -%}{{ section.settings.stamp_text }}{%- endif -%}
      </span>
      <p class="eyebrow" style="color: var(--sunset); margin-top:.75rem;">{{ section.settings.eyebrow }}</p>
      <h1 class="h1" style="margin-top:.5rem;">{{ section.settings.heading }}</h1>
      <p class="lede" style="margin-top:1rem;">{{ section.settings.lede }}</p>
    </div>

    <div class="preorder-form-wrap"
         style="margin: 2rem auto 0; background: var(--cream);
                border: 3px solid var(--ink); border-radius: 18px; padding: 2rem 1.75rem;
                box-shadow: 8px 8px 0 var(--ink);">

      {%- if sold_out -%}
        <p class="eyebrow" style="color: var(--sunset);">Waitlist</p>
        <h2 class="h2" style="margin-top:.25rem;">{{ section.settings.soldout_heading }}</h2>
        <p class="lede" style="margin-top:.75rem;">{{ section.settings.soldout_body }}</p>
        {%- if section.settings.soldout_cta_url != blank and section.settings.soldout_cta_text != blank -%}
          <a class="btn btn--primary" style="margin-top:1.25rem;"
             href="{{ section.settings.soldout_cta_url }}">{{ section.settings.soldout_cta_text }}</a>
        {%- endif -%}
      {%- else -%}

        <div style="display:flex; flex-wrap:wrap; gap:.6rem; justify-content:center; margin-bottom:1.25rem;">
          <div id="pill-8" style="padding:.55rem .9rem; background: var(--ink); color: var(--cream); border-radius: 999px; display:inline-flex; align-items:baseline; gap:.4rem;">
            <span style="font-family: 'Anton', sans-serif; letter-spacing:.06em; text-transform: uppercase; font-size:.75rem;">8-panel</span>
            <strong id="live-left-8" style="font-family: 'Anton', sans-serif; font-size: 1.15rem; line-height:1; color: {% if sold_8 %}var(--sunset){% else %}var(--acid){% endif %};">{{ left_8 }}</strong>
            <span style="font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.7rem;">/ <span id="live-max-8">{{ max_8 }}</span> left</span>
          </div>
          <div id="pill-32" style="padding:.55rem .9rem; background: var(--ink); color: var(--cream); border-radius: 999px; display:inline-flex; align-items:baseline; gap:.4rem;">
            <span style="font-family: 'Anton', sans-serif; letter-spacing:.06em; text-transform: uppercase; font-size:.75rem;">32-panel</span>
            <strong id="live-left-32" style="font-family: 'Anton', sans-serif; font-size: 1.15rem; line-height:1; color: {% if sold_32 %}var(--sunset){% else %}var(--acid){% endif %};">{{ left_32 }}</strong>
            <span style="font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.7rem;">/ <span id="live-max-32">{{ max_32 }}</span> left</span>
          </div>
          {%- if section.settings.price != blank -%}
            <div style="padding:.55rem .9rem; background: var(--sunset); color: var(--cream); border-radius: 999px; display:inline-flex; align-items:baseline; gap:.4rem;">
              <strong style="font-family: 'Anton', sans-serif; font-size: 1.15rem; line-height:1;">{{ section.settings.price }}</strong>
              <span style="font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.7rem;">per sack</span>
            </div>
          {%- endif -%}
        </div>

        {% form 'customer', class: 'preorder-form', novalidate: 'novalidate' %}
          <input type="hidden" name="contact[accepts_marketing]" value="true">
          <div style="display:grid; gap:.9rem;">

            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap:.6rem;">
              <label style="display:block;">
                <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.85rem; margin-bottom:.3rem;">First name</span>
                <input type="text" name="contact[first_name]" required autocomplete="given-name"
                       style="width:100%; padding:.7rem .85rem; border:2px solid var(--ink); border-radius: 10px; font-size:1rem; background: #fff;">
              </label>
              <label style="display:block;">
                <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.85rem; margin-bottom:.3rem;">Last name</span>
                <input type="text" name="contact[last_name]" required autocomplete="family-name"
                       style="width:100%; padding:.7rem .85rem; border:2px solid var(--ink); border-radius: 10px; font-size:1rem; background: #fff;">
              </label>
            </div>

            <label style="display:block;">
              <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.85rem; margin-bottom:.3rem;">Email</span>
              <input type="email" name="contact[email]" required autocomplete="email"
                     placeholder="you@sunpunks.beach"
                     style="width:100%; padding:.7rem .85rem; border:2px solid var(--ink); border-radius: 10px; font-size:1rem; background: #fff;">
            </label>

            <div>
              <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.85rem; margin-bottom:.4rem;">Pick your sack</span>
              <div style="display:grid; grid-template-columns: 1fr 1fr; gap:.6rem;">
                <button type="button" id="pick-8" data-style="8panel"
                        {% if sold_8 %}disabled{% endif %}
                        style="background:#fff; border:2px solid var(--ink); border-radius:10px; padding:.85rem .6rem; cursor:pointer; text-align:center; transition: background .15s, color .15s; {% if sold_8 %}opacity:.45; cursor:not-allowed;{% endif %}">
                  <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.04em; text-transform: uppercase; font-size:.95rem; color: var(--ink);">8-panel</span>
                  <span style="display:block; font-family: 'Pacifico', cursive; font-size:.85rem; margin-top:.2rem; color: var(--ink); opacity:.7;">classic</span>
                </button>
                <button type="button" id="pick-32" data-style="32panel"
                        {% if sold_32 %}disabled{% endif %}
                        style="background:#fff; border:2px solid var(--ink); border-radius:10px; padding:.85rem .6rem; cursor:pointer; text-align:center; transition: background .15s, color .15s; {% if sold_32 %}opacity:.45; cursor:not-allowed;{% endif %}">
                  <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.04em; text-transform: uppercase; font-size:.95rem; color: var(--ink);">32-panel</span>
                  <span style="display:block; font-family: 'Pacifico', cursive; font-size:.85rem; margin-top:.2rem; color: var(--ink); opacity:.7;">pro</span>
                </button>
              </div>
              <p id="pick-error"
                 style="display:none; margin-top:.5rem; color: var(--sunset); font-size:.85rem;">
                Pick 8-panel or 32-panel first.
              </p>
            </div>

            <div id="qty-wrap"
                 style="background:#fff; border:2px solid var(--ink); border-radius:10px; padding:.85rem 1rem;">
              <div style="display:flex; align-items:center; justify-content:space-between; gap:.75rem; margin-bottom:.6rem;">
                <span style="font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.85rem;">How many?</span>
                <span style="font-family: 'Anton', sans-serif; letter-spacing:.04em; text-transform: uppercase; font-size:.75rem; opacity:.6;">Max <span id="qty-max">45</span></span>
              </div>
              <div style="display:flex; align-items:stretch; gap:.5rem;">
                <button type="button" id="qty-minus" aria-label="Decrease quantity"
                        style="flex:0 0 auto; width:48px; background: var(--ink); color: var(--cream); border:none; border-radius:10px; font-family: 'Anton', sans-serif; font-size:1.5rem; line-height:1; cursor:pointer;">−</button>
                <input type="number" id="qty-input" min="1" max="45" value="1" step="1" inputmode="numeric"
                       style="flex:1 1 auto; width:100%; padding:.6rem .5rem; border:2px solid var(--ink); border-radius:10px; font-family: 'Anton', sans-serif; font-size:1.5rem; text-align:center; background:#fff; color: var(--ink); -moz-appearance:textfield;">
                <button type="button" id="qty-plus" aria-label="Increase quantity"
                        style="flex:0 0 auto; width:48px; background: var(--sunset); color: var(--cream); border:none; border-radius:10px; font-family: 'Anton', sans-serif; font-size:1.5rem; line-height:1; cursor:pointer;">+</button>
              </div>
              <input type="range" id="qty-slider" min="1" max="45" value="1" step="1"
                     style="width:100%; margin-top:.75rem; accent-color: var(--sunset);">
            </div>
            <style>
              #qty-input::-webkit-outer-spin-button,
              #qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
            </style>

            <div style="padding:.7rem 1rem; background: var(--ink); color: var(--cream); border-radius: 10px; display:flex; align-items:baseline; justify-content:space-between; gap:.5rem; font-family: 'Anton', sans-serif; letter-spacing:.04em; text-transform: uppercase;">
              <span><span id="total-qty">0</span> sacks</span>
              <strong style="color: var(--acid); font-size:1.2rem;"><span id="total-price">$0.00</span></strong>
            </div>

            <input type="hidden" name="contact[tags]" id="preorder-tags" value="hackysack-preorder, newsletter">
            <input type="hidden" name="contact[note]" id="preorder-note" value="">

            <button class="btn btn--primary" type="submit" style="margin-top:.5rem;">
              {{ section.settings.button_text }}
            </button>

            <p class="muted" style="font-size:.85rem; margin-top:.25rem; text-align:center;">
              {{ section.settings.trust_microcopy }}
            </p>

            {%- if form.posted_successfully? -%}
              <p style="margin-top:.5rem; padding:.75rem 1rem; background: var(--acid); color: var(--ink); border-radius: 10px; font-family: 'Anton', sans-serif; letter-spacing:.04em; text-transform: uppercase; text-align:center;">
                You're in. We'll email you when the drop goes live.
              </p>
            {%- endif -%}

            {%- if form.errors -%}
              <p style="margin-top:.5rem; padding:.75rem 1rem; background: #ffe1d6; color: var(--ink); border-radius: 10px;">
                {{ form.errors | default_errors }}
              </p>
            {%- endif -%}
          </div>
        {% endform %}
      {%- endif -%}
    </div>
  </div>
</section>

<script>
(function() {
  const root = document.getElementById('preorder-section');
  if (!root) return;

  const priceNum  = parseFloat((root.dataset.price || '').replace(/[^0-9.]/g, '')) || 0;
  const priceText = root.dataset.price || '';
  const workerUrl = (root.dataset.workerUrl || '').replace(/\/+$/, '');

  // Server-rendered fallback counts (from theme settings). If the Worker
  // is configured and reachable, these get overwritten on load.
  let left8  = parseInt(root.dataset.left8,  10) || 0;
  let left32 = parseInt(root.dataset.left32, 10) || 0;

  const pick8  = document.getElementById('pick-8');
  const pick32 = document.getElementById('pick-32');
  const slider = document.getElementById('qty-slider');
  const qtyInput = document.getElementById('qty-input');
  const qtyMinus = document.getElementById('qty-minus');
  const qtyPlus  = document.getElementById('qty-plus');
  const qtyMax = document.getElementById('qty-max');
  const totalQty = document.getElementById('total-qty');
  const totalPrice = document.getElementById('total-price');
  const pickError = document.getElementById('pick-error');
  const tagsEl = document.getElementById('preorder-tags');
  const noteEl = document.getElementById('preorder-note');
  const liveLeft8  = document.getElementById('live-left-8');
  const liveLeft32 = document.getElementById('live-left-32');
  const liveMax8   = document.getElementById('live-max-8');
  const liveMax32  = document.getElementById('live-max-32');

  let chosenStyle = null;
  const ABSOLUTE_MAX = 45;
  // The qty controls always span 1..45 in the UI regardless of per-style
  // remaining. Server-side / Worker validates on submit and returns 409
  // if the picked style can't fulfill the requested quantity.
  let currentCap = ABSOLUTE_MAX;

  function setCap() {
    if (qtyMax) qtyMax.textContent = ABSOLUTE_MAX;
    if (slider) slider.max = String(ABSOLUTE_MAX);
    if (qtyInput) qtyInput.max = String(ABSOLUTE_MAX);
  }
  setCap();

  function getQty() {
    const v = parseInt((qtyInput && qtyInput.value) || '1', 10);
    if (isNaN(v) || v < 1) return 1;
    if (v > currentCap) return currentCap;
    return v;
  }

  function setQty(n) {
    let v = parseInt(n, 10);
    if (isNaN(v) || v < 1) v = 1;
    if (v > currentCap) v = currentCap;
    if (qtyInput) qtyInput.value = String(v);
    if (slider)   slider.value   = String(v);
    updateTotals();
  }

  function updateTotals() {
    const qty = getQty();
    if (totalQty)   totalQty.textContent   = qty;
    if (totalPrice) totalPrice.textContent = '$' + (qty * priceNum).toFixed(2);

    const tagList = ['hackysack-preorder', 'newsletter'];
    if (chosenStyle === '8panel')  tagList.push('hackysack-8panel');
    if (chosenStyle === '32panel') tagList.push('hackysack-32panel');
    if (tagsEl) tagsEl.value = tagList.join(', ');

    if (noteEl) {
      if (chosenStyle) {
        const label = chosenStyle === '8panel' ? '8-panel' : '32-panel';
        noteEl.value = 'Preorder: ' + qty + 'x ' + label + ' (' + priceText + ' each · $' + (qty * priceNum).toFixed(2) + ' total)';
      } else {
        noteEl.value = '';
      }
    }
  }

  function applyLiveCounts(left_8, left_32, max_8, max_32) {
    left8  = left_8;
    left32 = left_32;
    if (liveLeft8)  liveLeft8.textContent  = left_8;
    if (liveLeft32) liveLeft32.textContent = left_32;
    if (typeof max_8  === 'number' && liveMax8)  liveMax8.textContent  = max_8;
    if (typeof max_32 === 'number' && liveMax32) liveMax32.textContent = max_32;

    if (left_8 <= 0 && pick8) {
      pick8.disabled = true;
      pick8.style.opacity = '.45';
      pick8.style.cursor = 'not-allowed';
      if (liveLeft8) liveLeft8.style.color = 'var(--sunset)';
      if (chosenStyle === '8panel') chosenStyle = null;
    }
    if (left_32 <= 0 && pick32) {
      pick32.disabled = true;
      pick32.style.opacity = '.45';
      pick32.style.cursor = 'not-allowed';
      if (liveLeft32) liveLeft32.style.color = 'var(--sunset)';
      if (chosenStyle === '32panel') chosenStyle = null;
    }
  }

  if (workerUrl) {
    fetch(workerUrl + '/', { method: 'GET' })
      .then(r => r.ok ? r.json() : null)
      .then(data => {
        if (data && typeof data.left8 === 'number' && typeof data.left32 === 'number') {
          applyLiveCounts(data.left8, data.left32, data.max8, data.max32);
        }
      })
      .catch(() => {});
  }

  function setPickedVisual(btn, picked) {
    if (!btn) return;
    btn.style.background = picked ? 'var(--sunset)' : '#fff';
    btn.querySelectorAll('span').forEach(s => {
      s.style.color = picked ? 'var(--cream)' : 'var(--ink)';
    });
  }

  function pickStyle(style) {
    chosenStyle = style;
    setPickedVisual(pick8,  style === '8panel');
    setPickedVisual(pick32, style === '32panel');
    if (pickError) pickError.style.display = 'none';
    updateTotals();
  }

  if (pick8)  pick8.addEventListener('click',  () => pickStyle('8panel'));
  if (pick32) pick32.addEventListener('click', () => pickStyle('32panel'));

  if (qtyMinus) qtyMinus.addEventListener('click', () => setQty(getQty() - 1));
  if (qtyPlus)  qtyPlus.addEventListener('click',  () => setQty(getQty() + 1));
  if (qtyInput) {
    qtyInput.addEventListener('input',  () => { if (slider) slider.value = qtyInput.value; updateTotals(); });
    qtyInput.addEventListener('blur',   () => setQty(qtyInput.value));
  }
  if (slider)   slider.addEventListener('input',   () => setQty(slider.value));

  function fireEmailMirror(qty) {
    try {
      const firstName = (form.querySelector('input[name="contact[first_name]"]') || {}).value || '';
      const lastName  = (form.querySelector('input[name="contact[last_name]"]')  || {}).value || '';
      const email     = (form.querySelector('input[name="contact[email]"]')      || {}).value || '';
      const styleLabel = chosenStyle === '8panel' ? '8-panel (classic)' : '32-panel (pro)';
      const totalAmt   = (qty * priceNum).toFixed(2);
      const payload = {
        Name: (firstName + ' ' + lastName).trim(),
        Email: email,
        Style: styleLabel,
        Quantity: qty,
        'Price per sack': priceText,
        Total: '$' + totalAmt,
        _subject: 'New hacky sack preorder: ' + qty + 'x ' + styleLabel,
        _captcha: 'false'
      };
      fetch('https://formsubmit.co/ajax/mikeodonnell30a@gmail.com', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(payload),
        keepalive: true
      }).catch(function(){});
    } catch (err) {}
  }

  const form = document.querySelector('.preorder-form');
  if (form) {
    form.addEventListener('submit', async function(e) {
      if (!chosenStyle) {
        e.preventDefault();
        if (pickError) pickError.style.display = 'block';
        if (pick8) pick8.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return false;
      }
      if (!form.checkValidity()) return; // let HTML5 validation handle it

      const qty = parseInt(slider.value, 10) || 1;

      // If a Worker is configured, reserve the spots there BEFORE letting the
      // form submit to Shopify. This is what makes the count live for everyone.
      if (workerUrl) {
        e.preventDefault();
        try {
          const res = await fetch(workerUrl + '/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ style: chosenStyle, qty: qty })
          });
          if (res.status === 409) {
            const data = await res.json().catch(() => ({}));
            if (typeof data.left8 === 'number') applyLiveCounts(data.left8, data.left32, data.max8, data.max32);
            if (pickError) {
              pickError.textContent = 'That style just sold out for that quantity. Try another or pick fewer.';
              pickError.style.display = 'block';
            }
            return;
          }
          if (!res.ok) throw new Error('worker_unreachable');
          const data = await res.json();
          if (typeof data.left8 === 'number') applyLiveCounts(data.left8, data.left32, data.max8, data.max32);
        } catch (err) {
          // Worker unreachable — fall through and let the form submit anyway.
          // Merchant still gets the formsubmit email and can adjust manually.
        }
        fireEmailMirror(qty);
        form.submit();
        return;
      }

      // No Worker configured → original flow (form submits normally to Shopify)
      fireEmailMirror(qty);
    });
  }

  updateTotals();
})();
</script>

{% schema %}
{
  "name": "Preorder — Hacky Sack",
  "settings": [
    { "type": "header", "content": "Spot caps (per style)" },
    { "type": "number", "id": "max_8panel",   "label": "Max 8-panel spots",   "default": 45 },
    { "type": "number", "id": "max_32panel",  "label": "Max 32-panel spots",  "default": 45 },

    { "type": "header", "content": "Spots taken so far" },
    { "type": "paragraph", "content": "Update manually as preorders roll in. Shopify admin → Customers → filter by tag hackysack-8panel or hackysack-32panel → open each customer to read the quantity in their note → sum totals → enter here." },
    { "type": "number", "id": "taken_8panel",  "label": "8-panel spots taken",  "default": 0 },
    { "type": "number", "id": "taken_32panel", "label": "32-panel spots taken", "default": 0 },

    { "type": "header", "content": "Live counter (Cloudflare Worker)" },
    { "type": "paragraph", "content": "Paste the deployed Worker URL (e.g. https://hackysack-counter.your-account.workers.dev). When set, the page fetches live counts on load and auto-decrements on each preorder for ALL visitors. Leave blank to use the manual 'Spots taken so far' fallback above." },
    { "type": "url",  "id": "worker_url", "label": "Counter API URL" },

    { "type": "header", "content": "Price" },
    { "type": "text", "id": "price", "label": "Price (per hacky sack)", "default": "$14.99" },

    { "type": "header", "content": "Hero" },
    { "type": "text",     "id": "stamp_text", "label": "Stamp text", "default": "First 90 only" },
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",    "default": "Sun Punks · Summer ’26 drop" },
    { "type": "text",     "id": "heading",    "label": "Heading",    "default": "Hacky Sacks. Punks circle up." },
    { "type": "textarea", "id": "lede",       "label": "Lede",
      "default": "Made for 30A. Hand-stitched, sand-tested footbags. First run is 90 total — 45 of each style. Save your spot." },

    { "type": "header", "content": "Signup form" },
    { "type": "text",     "id": "button_text",      "label": "Button text",      "default": "Save my spot →" },
    { "type": "textarea", "id": "trust_microcopy",  "label": "Trust microcopy",
      "default": "No payment now. You’ll be added to the Sun Punks list so we can ping you when the drop goes live. Unsubscribe whenever." },

    { "type": "header", "content": "Sold-out state (shows when BOTH styles are full)" },
    { "type": "text",     "id": "soldout_heading",  "label": "Sold-out heading",
      "default": "All 90 spots claimed." },
    { "type": "textarea", "id": "soldout_body",     "label": "Sold-out body",
      "default": "We sold through the first run. DM @sunpunksclothing on Instagram to land on the waitlist — we’ll reach out if any spots open up or when we line up a second run." },
    { "type": "text",     "id": "soldout_cta_text", "label": "Sold-out CTA text", "default": "DM us on Instagram" },
    { "type": "url",      "id": "soldout_cta_url",  "label": "Sold-out CTA URL" }
  ],
  "presets": [
    { "name": "Preorder — Hacky Sack" }
  ]
}
{% endschema %}
