{%- assign max_8   = section.settings.max_8panel    | default: 45 -%}
{%- assign max_32  = section.settings.max_32panel   | default: 45 -%}
{%- assign taken_8 = section.settings.taken_8panel  | default: 0  -%}
{%- assign taken_32 = section.settings.taken_32panel | default: 0 -%}

{%- assign left_8  = max_8  | minus: taken_8  -%}
{%- assign left_32 = max_32 | minus: taken_32 -%}
{%- if left_8  < 0 -%}{%- assign left_8  = 0 -%}{%- endif -%}
{%- if left_32 < 0 -%}{%- assign left_32 = 0 -%}{%- endif -%}

{%- assign max_total  = max_8  | plus: max_32 -%}
{%- assign left_total = left_8 | plus: left_32 -%}

{%- assign sold_8  = false -%}{%- if left_8  <= 0 -%}{%- assign sold_8  = true -%}{%- endif -%}
{%- assign sold_32 = false -%}{%- if left_32 <= 0 -%}{%- assign sold_32 = true -%}{%- endif -%}
{%- assign sold_out = false -%}{%- if sold_8 and sold_32 -%}{%- assign sold_out = true -%}{%- endif -%}

<section class="preorder-hero"
         style="background: linear-gradient(180deg, #f9d9bf 0%, var(--sand) 100%); border-bottom: 4px solid var(--acid); padding: 4rem 0 3rem;">
  <div class="container">
    <div class="preorder-hero__grid"
         style="display:grid; gap:3rem; align-items:center; grid-template-columns: 1.2fr .8fr;">
      <div data-anim="left">
        <span class="coming-stamp">
          {%- if sold_out -%}Sold out{%- else -%}{{ section.settings.stamp_text }}{%- endif -%}
        </span>
        <p class="eyebrow" style="color: var(--sunset); margin-top:.75rem;">{{ section.settings.eyebrow }}</p>
        <h1 class="h1" style="margin-top:.5rem;">{{ section.settings.heading }}</h1>
        <p class="lede" style="margin-top:1rem; max-width: 52ch;">{{ section.settings.lede }}</p>

        <div class="preorder-counters"
             style="margin-top:1.75rem; display:flex; flex-wrap:wrap; gap:.75rem;">
          {%- if sold_out -%}
            <div style="padding:.85rem 1.2rem; background: var(--ink); color: var(--cream); border-radius: 999px; box-shadow: 0 6px 0 var(--acid);">
              <strong style="font-family: 'Anton', sans-serif; font-size: 1.3rem; letter-spacing:.04em;">ALL {{ max_total }} SPOTS CLAIMED</strong>
            </div>
          {%- else -%}
            <div style="padding:.7rem 1.1rem; background: var(--ink); color: var(--cream); border-radius: 999px; display:inline-flex; align-items:baseline; gap:.5rem;">
              <span style="font-family: 'Anton', sans-serif; letter-spacing:.06em; text-transform: uppercase; font-size:.85rem;">8-panel</span>
              <strong style="font-family: 'Anton', sans-serif; font-size: 1.4rem; line-height:1; color: {% if sold_8 %}var(--sunset){% else %}var(--acid){% endif %};">{{ left_8 }}</strong>
              <span style="font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.8rem;">/ {{ max_8 }} left</span>
            </div>
            <div style="padding:.7rem 1.1rem; background: var(--ink); color: var(--cream); border-radius: 999px; display:inline-flex; align-items:baseline; gap:.5rem;">
              <span style="font-family: 'Anton', sans-serif; letter-spacing:.06em; text-transform: uppercase; font-size:.85rem;">32-panel</span>
              <strong style="font-family: 'Anton', sans-serif; font-size: 1.4rem; line-height:1; color: {% if sold_32 %}var(--sunset){% else %}var(--acid){% endif %};">{{ left_32 }}</strong>
              <span style="font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.8rem;">/ {{ max_32 }} left</span>
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="preorder-hero__visual" aria-hidden="true" data-anim="scale"
           style="display:flex; justify-content:center;">
        <div class="hacky-sack" style="transform: scale(1.15);"></div>
      </div>
    </div>
  </div>
</section>

<section class="section" id="reserve" style="padding: 3rem 0;">
  <div class="container">
    <div class="preorder-form-wrap"
         style="max-width: 560px; margin: 0 auto; background: var(--cream);
                border: 3px solid var(--ink); border-radius: 18px; padding: 2rem 1.75rem;
                box-shadow: 8px 8px 0 var(--ink);">

      {%- if sold_out -%}
        <p class="eyebrow" style="color: var(--sunset);">Waitlist</p>
        <h2 class="h2" style="margin-top:.25rem;">{{ section.settings.soldout_heading }}</h2>
        <p class="lede" style="margin-top:.75rem;">{{ section.settings.soldout_body }}</p>
        {%- if section.settings.soldout_cta_url != blank and section.settings.soldout_cta_text != blank -%}
          <a class="btn btn--primary" style="margin-top:1.25rem;"
             href="{{ section.settings.soldout_cta_url }}">{{ section.settings.soldout_cta_text }}</a>
        {%- endif -%}
      {%- else -%}
        <p class="eyebrow" style="color: var(--sunset);">{{ section.settings.form_eyebrow }}</p>
        <h2 class="h2" style="margin-top:.25rem;">{{ section.settings.form_heading }}</h2>
        <p class="muted" style="margin-top:.5rem;">{{ section.settings.form_subtext }}</p>

        {% form 'customer', class: 'preorder-form', novalidate: 'novalidate' %}
          <div style="display:grid; gap:.9rem; margin-top:1.25rem;">

            <label style="display:block;">
              <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.85rem; margin-bottom:.3rem;">First name</span>
              <input type="text" name="contact[first_name]" required autocomplete="given-name"
                     style="width:100%; padding:.7rem .85rem; border:2px solid var(--ink); border-radius: 10px; font-size:1rem; background: #fff;">
            </label>

            <label style="display:block;">
              <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.85rem; margin-bottom:.3rem;">Email</span>
              <input type="email" name="contact[email]" required autocomplete="email"
                     placeholder="you@sunpunks.beach"
                     style="width:100%; padding:.7rem .85rem; border:2px solid var(--ink); border-radius: 10px; font-size:1rem; background: #fff;">
            </label>

            <label style="display:block;">
              <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.85rem; margin-bottom:.3rem;">Which one?</span>
              <select name="contact[tags]" required
                      style="width:100%; padding:.7rem .85rem; border:2px solid var(--ink); border-radius: 10px; font-size:1rem; background: #fff;">
                <option value="" disabled selected>Pick one…</option>
                {%- unless sold_8 -%}
                  <option value="hackysack-preorder, hackysack-8panel">8-panel (classic) — {{ left_8 }} left</option>
                {%- endunless -%}
                {%- unless sold_32 -%}
                  <option value="hackysack-preorder, hackysack-32panel">32-panel (pro) — {{ left_32 }} left</option>
                {%- endunless -%}
                {%- unless sold_8 or sold_32 -%}
                  <option value="hackysack-preorder, hackysack-8panel, hackysack-32panel">One of each</option>
                {%- endunless -%}
              </select>
            </label>

            <button class="btn btn--primary" type="submit" style="margin-top:.5rem;">
              {{ section.settings.button_text }}
            </button>

            <p class="muted" style="font-size:.85rem; margin-top:.25rem;">
              {{ section.settings.trust_microcopy }}
            </p>

            {%- if form.posted_successfully? -%}
              <p style="margin-top:.5rem; padding:.75rem 1rem; background: var(--acid); color: var(--ink); border-radius: 10px; font-family: 'Anton', sans-serif; letter-spacing:.04em; text-transform: uppercase;">
                You're in. We'll email you when the drop goes live.
              </p>
            {%- endif -%}

            {%- if form.errors -%}
              <p style="margin-top:.5rem; padding:.75rem 1rem; background: #ffe1d6; color: var(--ink); border-radius: 10px;">
                {{ form.errors | default_errors }}
              </p>
            {%- endif -%}
          </div>
        {% endform %}

        {%- if sold_8 or sold_32 -%}
          <p class="muted" style="margin-top: 1rem; font-size:.85rem;">
            {%- if sold_8 -%}Heads up: 8-panel is sold out — only 32-panel spots remain.{%- endif -%}
            {%- if sold_32 -%}Heads up: 32-panel is sold out — only 8-panel spots remain.{%- endif -%}
          </p>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</section>

{%- if section.blocks.size > 0 -%}
  <section class="section section--tight" style="padding: 2rem 0 4rem;">
    <div class="container">
      <div class="preorder-features"
           style="display:grid; gap:1.5rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <div data-anim
                 style="background: var(--cream); border: 2px solid var(--ink); border-radius: 14px; padding: 1.25rem 1.25rem 1.5rem;"
                 {{ block.shopify_attributes }}>
              {%- if block.settings.icon_emoji != blank -%}
                <div style="font-size:1.75rem; line-height:1;">{{ block.settings.icon_emoji }}</div>
              {%- endif -%}
              <h3 style="font-family: 'Anton', sans-serif; text-transform: uppercase; letter-spacing:.04em; margin-top:.5rem;">{{ block.settings.title }}</h3>
              <p class="muted" style="margin-top:.4rem;">{{ block.settings.body }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

<style>
  @media (max-width: 740px) {
    .preorder-hero__grid { grid-template-columns: 1fr !important; }
    .preorder-hero__visual { order: -1; }
  }
</style>

{% schema %}
{
  "name": "Preorder — Hacky Sack",
  "settings": [
    { "type": "header", "content": "Spot caps (per style)" },
    { "type": "number", "id": "max_8panel",   "label": "Max 8-panel spots",   "default": 45 },
    { "type": "number", "id": "max_32panel",  "label": "Max 32-panel spots",  "default": 45 },

    { "type": "header", "content": "Spots taken so far" },
    { "type": "paragraph", "content": "Update manually as signups roll in. Shopify admin → Customers → filter by tag hackysack-8panel or hackysack-32panel → see count → enter here." },
    { "type": "number", "id": "taken_8panel",  "label": "8-panel signups so far",  "default": 0 },
    { "type": "number", "id": "taken_32panel", "label": "32-panel signups so far", "default": 0 },

    { "type": "header", "content": "Hero" },
    { "type": "text",     "id": "stamp_text", "label": "Stamp text", "default": "First 90 only" },
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",    "default": "Sun Punks · Summer ’26 drop" },
    { "type": "text",     "id": "heading",    "label": "Heading",    "default": "Hacky Sacks. Punks circle up." },
    { "type": "textarea", "id": "lede",       "label": "Lede",
      "default": "Hand-stitched, sand-tested footbags built for barefoot beach circles, parking-lot kick-arounds, and sunset hangs on the 30A. First run is 90 total — 45 of each style. Claim yours." },

    { "type": "header", "content": "Signup form" },
    { "type": "text",     "id": "form_eyebrow",     "label": "Form eyebrow",     "default": "Reserve your spot" },
    { "type": "text",     "id": "form_heading",     "label": "Form heading",     "default": "Save my hacky sack." },
    { "type": "textarea", "id": "form_subtext",     "label": "Form subtext",
      "default": "Drop your email. We’ll DM you when the drop goes live and you get first dibs at one of the 90." },
    { "type": "text",     "id": "button_text",      "label": "Button text",      "default": "Save my spot →" },
    { "type": "textarea", "id": "trust_microcopy",  "label": "Trust microcopy",
      "default": "No payment now. Just hopping the line. Unsubscribe whenever." },

    { "type": "header", "content": "Sold-out state (shows when BOTH styles are full)" },
    { "type": "text",     "id": "soldout_heading",  "label": "Sold-out heading",
      "default": "All 90 spots claimed." },
    { "type": "textarea", "id": "soldout_body",     "label": "Sold-out body",
      "default": "We sold through the first run. DM @sunpunksclothing on Instagram to land on the waitlist — we’ll reach out if any spots open up or when we line up a second run." },
    { "type": "text",     "id": "soldout_cta_text", "label": "Sold-out CTA text", "default": "DM us on Instagram" },
    { "type": "url",      "id": "soldout_cta_url",  "label": "Sold-out CTA URL" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature card",
      "settings": [
        { "type": "text",     "id": "icon_emoji", "label": "Emoji / icon", "default": "🌅" },
        { "type": "text",     "id": "title",      "label": "Title",        "default": "Made on 30A" },
        { "type": "textarea", "id": "body",       "label": "Body",
          "default": "Stitched by hand on the panhandle. Salt-tested before they ship." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Preorder — Hacky Sack",
      "blocks": [
        { "type": "feature", "settings": { "icon_emoji": "🌅", "title": "Made on 30A",      "body": "Stitched by hand on the panhandle. Salt-tested before they ship." } },
        { "type": "feature", "settings": { "icon_emoji": "🟠", "title": "8 or 32 panel",    "body": "Classic 8-panel for chill circles. 32-panel for the pros stalling at sunset." } },
        { "type": "feature", "settings": { "icon_emoji": "🔥", "title": "First 90 only",    "body": "When the 90 are claimed, we close the list. No restock guaranteed." } }
      ]
    }
  ]
}
{% endschema %}
