{%- assign max_8   = section.settings.max_8panel    | default: 45 -%}
{%- assign max_32  = section.settings.max_32panel   | default: 45 -%}
{%- assign taken_8 = section.settings.taken_8panel  | default: 0  -%}
{%- assign taken_32 = section.settings.taken_32panel | default: 0 -%}

{%- assign left_8  = max_8  | minus: taken_8  -%}
{%- assign left_32 = max_32 | minus: taken_32 -%}
{%- if left_8  < 0 -%}{%- assign left_8  = 0 -%}{%- endif -%}
{%- if left_32 < 0 -%}{%- assign left_32 = 0 -%}{%- endif -%}

{%- assign sold_8  = false -%}{%- if left_8  <= 0 -%}{%- assign sold_8  = true -%}{%- endif -%}
{%- assign sold_32 = false -%}{%- if left_32 <= 0 -%}{%- assign sold_32 = true -%}{%- endif -%}
{%- assign sold_out = false -%}{%- if sold_8 and sold_32 -%}{%- assign sold_out = true -%}{%- endif -%}

<section class="preorder-page"
         id="preorder-section"
         data-max-8="{{ max_8 }}"
         data-max-32="{{ max_32 }}"
         data-server-left-8="{{ left_8 }}"
         data-server-left-32="{{ left_32 }}"
         data-price="{{ section.settings.price }}"
         style="background: linear-gradient(180deg, #f9d9bf 0%, var(--sand) 100%); padding: 4rem 0 5rem; min-height: 80vh;">
  <div class="container" style="max-width: 620px;">

    <div style="text-align:center;" data-anim>
      <span class="coming-stamp" id="preorder-stamp">
        {%- if sold_out -%}Sold out{%- else -%}{{ section.settings.stamp_text }}{%- endif -%}
      </span>
      <p class="eyebrow" style="color: var(--sunset); margin-top:.75rem;">{{ section.settings.eyebrow }}</p>
      <h1 class="h1" style="margin-top:.5rem;">{{ section.settings.heading }}</h1>
      <p class="lede" style="margin-top:1rem;">{{ section.settings.lede }}</p>
    </div>

    <div class="preorder-form-wrap"
         style="margin: 2rem auto 0; background: var(--cream);
                border: 3px solid var(--ink); border-radius: 18px; padding: 2rem 1.75rem;
                box-shadow: 8px 8px 0 var(--ink);">

      <div id="preorder-soldout" style="{% unless sold_out %}display:none;{% endunless %}">
        <p class="eyebrow" style="color: var(--sunset);">Waitlist</p>
        <h2 class="h2" style="margin-top:.25rem;">{{ section.settings.soldout_heading }}</h2>
        <p class="lede" style="margin-top:.75rem;">{{ section.settings.soldout_body }}</p>
        {%- if section.settings.soldout_cta_url != blank and section.settings.soldout_cta_text != blank -%}
          <a class="btn btn--primary" style="margin-top:1.25rem;"
             href="{{ section.settings.soldout_cta_url }}">{{ section.settings.soldout_cta_text }}</a>
        {%- endif -%}
      </div>

      <div id="preorder-live" style="{% if sold_out %}display:none;{% endif %}">
        <div style="display:flex; flex-wrap:wrap; gap:.6rem; justify-content:center; margin-bottom:1.25rem;">
          <div id="pill-8" style="padding:.55rem .9rem; background: var(--ink); color: var(--cream); border-radius: 999px; display:inline-flex; align-items:baseline; gap:.4rem;">
            <span style="font-family: 'Anton', sans-serif; letter-spacing:.06em; text-transform: uppercase; font-size:.75rem;">8-panel</span>
            <strong id="live-left-8"
                    style="font-family: 'Anton', sans-serif; font-size: 1.15rem; line-height:1; color: {% if sold_8 %}var(--sunset){% else %}var(--acid){% endif %};">{{ left_8 }}</strong>
            <span style="font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.7rem;">/ {{ max_8 }} left</span>
          </div>
          <div id="pill-32" style="padding:.55rem .9rem; background: var(--ink); color: var(--cream); border-radius: 999px; display:inline-flex; align-items:baseline; gap:.4rem;">
            <span style="font-family: 'Anton', sans-serif; letter-spacing:.06em; text-transform: uppercase; font-size:.75rem;">32-panel</span>
            <strong id="live-left-32"
                    style="font-family: 'Anton', sans-serif; font-size: 1.15rem; line-height:1; color: {% if sold_32 %}var(--sunset){% else %}var(--acid){% endif %};">{{ left_32 }}</strong>
            <span style="font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.7rem;">/ {{ max_32 }} left</span>
          </div>
          {%- if section.settings.price != blank -%}
            <div style="padding:.55rem .9rem; background: var(--sunset); color: var(--cream); border-radius: 999px; display:inline-flex; align-items:baseline; gap:.4rem;">
              <strong style="font-family: 'Anton', sans-serif; font-size: 1.15rem; line-height:1;">{{ section.settings.price }}</strong>
              <span style="font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.7rem;">per sack</span>
            </div>
          {%- endif -%}
        </div>

        {% form 'customer', class: 'preorder-form', novalidate: 'novalidate' %}
          <input type="hidden" name="contact[accepts_marketing]" value="true">
          <div style="display:grid; gap:.9rem;">

            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap:.6rem;">
              <label style="display:block;">
                <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.85rem; margin-bottom:.3rem;">First name</span>
                <input type="text" name="contact[first_name]" required autocomplete="given-name"
                       style="width:100%; padding:.7rem .85rem; border:2px solid var(--ink); border-radius: 10px; font-size:1rem; background: #fff;">
              </label>
              <label style="display:block;">
                <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.85rem; margin-bottom:.3rem;">Last name</span>
                <input type="text" name="contact[last_name]" required autocomplete="family-name"
                       style="width:100%; padding:.7rem .85rem; border:2px solid var(--ink); border-radius: 10px; font-size:1rem; background: #fff;">
              </label>
            </div>

            <label style="display:block;">
              <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.85rem; margin-bottom:.3rem;">Email</span>
              <input type="email" name="contact[email]" required autocomplete="email"
                     placeholder="you@sunpunks.beach"
                     style="width:100%; padding:.7rem .85rem; border:2px solid var(--ink); border-radius: 10px; font-size:1rem; background: #fff;">
            </label>

            <div>
              <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.05em; text-transform: uppercase; font-size:.85rem; margin-bottom:.4rem;">How many of each?</span>
              <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap:.6rem;">
                <label id="qty-card-8" style="display:block; background:#fff; border:2px solid var(--ink); border-radius:10px; padding:.65rem .8rem;">
                  <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.04em; text-transform: uppercase; font-size:.75rem; color: var(--ink);">8-panel · classic</span>
                  <input type="number" id="qty_8" min="0" max="{{ left_8 }}" value="0" inputmode="numeric"
                         {% if sold_8 %}disabled{% endif %}
                         style="width:100%; margin-top:.25rem; padding:.4rem .25rem; border:none; outline:none; font-size:1.4rem; font-family: 'Anton', sans-serif; background:transparent; color: var(--ink);">
                  <small id="qty-hint-8" style="display:block; color: var(--ink); opacity:.6; font-size:.7rem; margin-top:.15rem;">
                    {%- if sold_8 -%}Sold out{%- else -%}<span id="qty-left-8">{{ left_8 }}</span> left at {{ section.settings.price }}{%- endif -%}
                  </small>
                </label>
                <label id="qty-card-32" style="display:block; background:#fff; border:2px solid var(--ink); border-radius:10px; padding:.65rem .8rem;">
                  <span style="display:block; font-family: 'Anton', sans-serif; letter-spacing:.04em; text-transform: uppercase; font-size:.75rem; color: var(--ink);">32-panel · pro</span>
                  <input type="number" id="qty_32" min="0" max="{{ left_32 }}" value="0" inputmode="numeric"
                         {% if sold_32 %}disabled{% endif %}
                         style="width:100%; margin-top:.25rem; padding:.4rem .25rem; border:none; outline:none; font-size:1.4rem; font-family: 'Anton', sans-serif; background:transparent; color: var(--ink);">
                  <small id="qty-hint-32" style="display:block; color: var(--ink); opacity:.6; font-size:.7rem; margin-top:.15rem;">
                    {%- if sold_32 -%}Sold out{%- else -%}<span id="qty-left-32">{{ left_32 }}</span> left at {{ section.settings.price }}{%- endif -%}
                  </small>
                </label>
              </div>
            </div>

            <div id="preorder-total"
                 style="padding:.7rem 1rem; background: var(--ink); color: var(--cream); border-radius: 10px; display:flex; align-items:baseline; justify-content:space-between; gap:.5rem; font-family: 'Anton', sans-serif; letter-spacing:.04em; text-transform: uppercase;">
              <span><span id="total-qty">0</span> sacks</span>
              <strong style="color: var(--acid); font-size:1.2rem;"><span id="total-price">$0.00</span></strong>
            </div>

            <p id="preorder-error"
               style="display:none; padding:.6rem .9rem; background:#ffe1d6; color: var(--ink); border-radius: 10px; font-size:.9rem;">
              Pick at least one hacky sack before saving your spot.
            </p>

            <input type="hidden" name="contact[tags]" id="preorder-tags" value="hackysack-preorder, newsletter">
            <input type="hidden" name="contact[note]" id="preorder-note" value="">

            <button class="btn btn--primary" type="submit" id="preorder-submit" style="margin-top:.5rem;">
              {{ section.settings.button_text }}
            </button>

            <p class="muted" style="font-size:.85rem; margin-top:.25rem; text-align:center;">
              {{ section.settings.trust_microcopy }}
            </p>

            {%- if form.posted_successfully? -%}
              <p id="preorder-success"
                 style="margin-top:.5rem; padding:.75rem 1rem; background: var(--acid); color: var(--ink); border-radius: 10px; font-family: 'Anton', sans-serif; letter-spacing:.04em; text-transform: uppercase; text-align:center;">
                You're in. We'll email you when the drop goes live.
              </p>
            {%- endif -%}

            {%- if form.errors -%}
              <p style="margin-top:.5rem; padding:.75rem 1rem; background: #ffe1d6; color: var(--ink); border-radius: 10px;">
                {{ form.errors | default_errors }}
              </p>
            {%- endif -%}
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  const root = document.getElementById('preorder-section');
  if (!root) return;

  const KEY_8  = 'sunpunks-hs-mine-8';
  const KEY_32 = 'sunpunks-hs-mine-32';
  const KEY_PENDING = 'sunpunks-hs-pending';

  const serverLeft8  = parseInt(root.dataset.serverLeft8,  10) || 0;
  const serverLeft32 = parseInt(root.dataset.serverLeft32, 10) || 0;
  const priceNum     = parseFloat((root.dataset.price || '').replace(/[^0-9.]/g, '')) || 0;
  const priceText    = root.dataset.price || '';

  // Apply any pending quantities from a successful submit that hasn't been re-rendered yet
  const success = document.getElementById('preorder-success');
  if (success) {
    const pending = JSON.parse(sessionStorage.getItem(KEY_PENDING) || 'null');
    if (pending) {
      const mine8  = (parseInt(localStorage.getItem(KEY_8),  10) || 0) + (pending.q8  || 0);
      const mine32 = (parseInt(localStorage.getItem(KEY_32), 10) || 0) + (pending.q32 || 0);
      localStorage.setItem(KEY_8,  String(mine8));
      localStorage.setItem(KEY_32, String(mine32));
      sessionStorage.removeItem(KEY_PENDING);
    }
  }

  const mine8  = parseInt(localStorage.getItem(KEY_8)  || '0', 10) || 0;
  const mine32 = parseInt(localStorage.getItem(KEY_32) || '0', 10) || 0;

  const adjLeft8  = Math.max(0, serverLeft8  - mine8);
  const adjLeft32 = Math.max(0, serverLeft32 - mine32);

  function setText(id, val) {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  }
  setText('live-left-8',  adjLeft8);
  setText('live-left-32', adjLeft32);
  setText('qty-left-8',   adjLeft8);
  setText('qty-left-32',  adjLeft32);

  const q8  = document.getElementById('qty_8');
  const q32 = document.getElementById('qty_32');
  if (q8)  q8.max  = adjLeft8;
  if (q32) q32.max = adjLeft32;

  const liveStrong8  = document.getElementById('live-left-8');
  const liveStrong32 = document.getElementById('live-left-32');
  const hint8 = document.getElementById('qty-hint-8');
  const hint32 = document.getElementById('qty-hint-32');

  if (adjLeft8 <= 0) {
    if (liveStrong8) liveStrong8.style.color = 'var(--sunset)';
    if (q8) { q8.disabled = true; q8.value = '0'; }
    if (hint8) hint8.textContent = 'Sold out';
  }
  if (adjLeft32 <= 0) {
    if (liveStrong32) liveStrong32.style.color = 'var(--sunset)';
    if (q32) { q32.disabled = true; q32.value = '0'; }
    if (hint32) hint32.textContent = 'Sold out';
  }

  // If both are sold out client-side, swap to the sold-out panel
  if (adjLeft8 <= 0 && adjLeft32 <= 0) {
    const live = document.getElementById('preorder-live');
    const so   = document.getElementById('preorder-soldout');
    const stamp = document.getElementById('preorder-stamp');
    if (live) live.style.display = 'none';
    if (so)   so.style.display   = 'block';
    if (stamp) stamp.textContent = 'Sold out';
    return;
  }

  function clamp(n, max) {
    if (isNaN(n) || n < 0) return 0;
    if (n > max) return max;
    return n;
  }

  function update() {
    if (!q8 || !q32) return;
    let a = clamp(parseInt(q8.value, 10),  adjLeft8);
    let b = clamp(parseInt(q32.value, 10), adjLeft32);
    if (q8.value  !== '' && String(a) !== q8.value)  q8.value  = a;
    if (q32.value !== '' && String(b) !== q32.value) q32.value = b;

    const total = a + b;
    setText('total-qty',   total);
    setText('total-price', '$' + (total * priceNum).toFixed(2));

    const tagList = ['hackysack-preorder', 'newsletter'];
    if (a > 0) tagList.push('hackysack-8panel');
    if (b > 0) tagList.push('hackysack-32panel');
    const tagsEl = document.getElementById('preorder-tags');
    if (tagsEl) tagsEl.value = tagList.join(', ');

    const noteParts = [];
    if (a > 0) noteParts.push(a + 'x 8-panel');
    if (b > 0) noteParts.push(b + 'x 32-panel');
    const noteEl = document.getElementById('preorder-note');
    if (noteEl) {
      noteEl.value = noteParts.length
        ? 'Preorder: ' + noteParts.join(', ') + ' (' + total + ' total · ' + priceText + ' each · $' + (total * priceNum).toFixed(2) + ' total)'
        : '';
    }

    const err = document.getElementById('preorder-error');
    if (err && total > 0) err.style.display = 'none';
  }

  if (q8)  q8.addEventListener('input',  update);
  if (q32) q32.addEventListener('input', update);

  const form = document.querySelector('.preorder-form');
  if (form) {
    form.addEventListener('submit', function(e) {
      const a = clamp(parseInt(q8 ? q8.value : 0, 10), adjLeft8);
      const b = clamp(parseInt(q32 ? q32.value : 0, 10), adjLeft32);
      if (a + b < 1) {
        e.preventDefault();
        const err = document.getElementById('preorder-error');
        if (err) err.style.display = 'block';
        return false;
      }
      // Stash so the post-redirect page can apply the decrement
      sessionStorage.setItem(KEY_PENDING, JSON.stringify({ q8: a, q32: b }));
    });
  }

  update();
})();
</script>

{% schema %}
{
  "name": "Preorder — Hacky Sack",
  "settings": [
    { "type": "header", "content": "Spot caps (per style)" },
    { "type": "number", "id": "max_8panel",   "label": "Max 8-panel spots",   "default": 45 },
    { "type": "number", "id": "max_32panel",  "label": "Max 32-panel spots",  "default": 45 },

    { "type": "header", "content": "Spots taken so far" },
    { "type": "paragraph", "content": "Update manually as preorders roll in. Shopify admin → Customers → filter by tag hackysack-8panel or hackysack-32panel → sum the quantities from each customer's note → enter total spots here." },
    { "type": "number", "id": "taken_8panel",  "label": "8-panel spots taken",  "default": 0 },
    { "type": "number", "id": "taken_32panel", "label": "32-panel spots taken", "default": 0 },

    { "type": "header", "content": "Price" },
    { "type": "text", "id": "price", "label": "Price (per hacky sack)", "default": "$14.99" },

    { "type": "header", "content": "Hero" },
    { "type": "text",     "id": "stamp_text", "label": "Stamp text", "default": "First 90 only" },
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",    "default": "Sun Punks · Summer ’26 drop" },
    { "type": "text",     "id": "heading",    "label": "Heading",    "default": "Hacky Sacks. Punks circle up." },
    { "type": "textarea", "id": "lede",       "label": "Lede",
      "default": "Made for 30A. Hand-stitched, sand-tested footbags. First run is 90 total — 45 of each style. Save your spot." },

    { "type": "header", "content": "Signup form" },
    { "type": "text",     "id": "button_text",      "label": "Button text",      "default": "Save my spot →" },
    { "type": "textarea", "id": "trust_microcopy",  "label": "Trust microcopy",
      "default": "No payment now. You’ll be added to the Sun Punks list so we can ping you when the drop goes live. Unsubscribe whenever." },

    { "type": "header", "content": "Sold-out state (shows when BOTH styles are full)" },
    { "type": "text",     "id": "soldout_heading",  "label": "Sold-out heading",
      "default": "All 90 spots claimed." },
    { "type": "textarea", "id": "soldout_body",     "label": "Sold-out body",
      "default": "We sold through the first run. DM @sunpunksclothing on Instagram to land on the waitlist — we’ll reach out if any spots open up or when we line up a second run." },
    { "type": "text",     "id": "soldout_cta_text", "label": "Sold-out CTA text", "default": "DM us on Instagram" },
    { "type": "url",      "id": "soldout_cta_url",  "label": "Sold-out CTA URL" }
  ],
  "presets": [
    { "name": "Preorder — Hacky Sack" }
  ]
}
{% endschema %}
