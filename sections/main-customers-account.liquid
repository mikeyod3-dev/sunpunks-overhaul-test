<section class="account-hero" data-account-loggedin>
  <div class="container">
    <p class="eyebrow">Your account</p>
    <h1 class="h1">Hey, <span class="mark-acid" data-account-name>{{ customer.first_name | default: 'punk' }}</span>.</h1>
    <div class="account-stats">
      <div class="account-stat"><b data-stat-orders>{{ customer.orders_count | default: 3 }}</b><small>orders</small></div>
      <div class="account-stat"><b data-stat-spent>{% if customer.total_spent and customer.total_spent > 0 %}{{ customer.total_spent | money }}{% else %}$64.97{% endif %}</b><small>spent</small></div>
      <div class="account-stat"><b data-stat-size>M</b><small>tee size</small></div>
    </div>
    <p style="margin-top:1.25rem;">
      <span class="account-since">
        Sun Punk since <b data-account-since>{{ customer.created_at | date: '%b %-d, %Y' }}</b>
        <span class="days" data-account-days></span>
      </span>
    </p>
  </div>
</section>

<section class="section" data-account-loggedin>
  <div class="container">
    <div class="account-grid">
      <div>
        <div class="account-card" data-anim="left">
          <h2>Your sizes <a href="#" data-edit-sizes>Edit</a></h2>
          <div class="size-grid">
            <div><b data-size-tee>M</b><small>Tee</small></div>
            <div><b data-size-bottom>32</b><small>Bottoms</small></div>
            <div><b data-size-shoe>10</b><small>Shoe</small></div>
          </div>
          <p class="muted" style="font-size:.8rem; margin-top:1rem;">Saved sizes pre-fill on every product page.</p>
        </div>

        <div class="account-card" style="margin-top:1.5rem;" data-anim="left">
          <h2>Profile</h2>
          <p><strong>Shipping name</strong><br/><span data-account-shipping-name>{{ customer.default_address.name | default: 'Mike O''Donnell' }}</span></p>
          <p style="margin-top:1rem;"><strong>Email</strong><br/><span data-account-email>{{ customer.email | default: 'you@thebeach.com' }}</span></p>
          <p style="margin-top:1rem;"><strong>Member since</strong><br/><span data-account-since-full>{{ customer.created_at | date: '%b %-d, %Y' | default: 'May 19, 2026' }}</span></p>
          <div class="cluster" style="margin-top:1.25rem;">
            <a href="{{ routes.account_addresses_url }}" class="btn btn--ghost btn--sm">Addresses</a>
            <a href="{{ routes.account_logout_url }}" class="btn btn--ghost btn--sm">Log out</a>
          </div>
        </div>
      </div>

      <div>
        <div class="account-card" data-anim="right">
          <h2>Order history <a href="{{ routes.account_url }}#latest">View latest →</a></h2>

          {%- if customer.orders.size > 0 -%}
            {%- for o in customer.orders limit: 5 -%}
              <div class="order">
                <div class="order__head">
                  <span class="order__id">#{{ o.order_number }}</span>
                  <span class="order__pill">{{ o.fulfillment_status_label | default: 'Processing' }} · {{ o.created_at | date: '%b %-d, %Y' }}</span>
                </div>
                <div class="order__items">
                  {%- for line in o.line_items -%}
                    <div class="order__line">
                      <div class="order__thumb" style="background:#1b2a3a;">
                        {%- if line.image -%}<img src="{{ line.image | image_url: width: 120 }}" alt="" width="56" height="56">{%- endif -%}
                      </div>
                      <div>
                        <strong>{{ line.product.title }}</strong>
                        <div class="order__meta">{{ line.variant.title }} · Qty {{ line.quantity }}</div>
                      </div>
                      <span>{{ line.final_line_price | money }}</span>
                    </div>
                  {%- endfor -%}
                </div>
                <div class="order__total"><span>Total</span><span>{{ o.total_price | money }}</span></div>
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- comment -%} Demo order history so the layout shows what it'll look like. {%- endcomment -%}
            <div class="order">
              <div class="order__head"><span class="order__id">#SP1056</span><span class="order__pill">Delivered · Apr 14, 2026</span></div>
              <div class="order__items">
                <div class="order__line"><div class="order__thumb" style="background:#1b2a3a;">TEE</div><div><strong>Sun Punk Summer Boxy Tee</strong><div class="order__meta">Sand · Size M · Qty 1</div></div><span>$20.00</span></div>
                <div class="order__line"><div class="order__thumb" style="background:#1f8a8f;">KOO</div><div><strong>Sun Punk Tribal Koozie</strong><div class="order__meta">Blue · One size · Qty 1</div></div><span>$4.99</span></div>
              </div>
              <div class="order__total"><span>Total</span><span>$24.99</span></div>
            </div>
            <div class="order">
              <div class="order__head"><span class="order__id">#SP1023</span><span class="order__pill order__pill--shipped">Shipped · Feb 02, 2026</span></div>
              <div class="order__items">
                <div class="order__line"><div class="order__thumb" style="background:#ead8b2; color:#1b2a3a;">TOTE</div><div><strong>Cotton Canvas Tote Bag</strong><div class="order__meta">Eco · Qty 1</div></div><span>$14.99</span></div>
              </div>
              <div class="order__total"><span>Total</span><span>$14.99</span></div>
            </div>
            <div class="order">
              <div class="order__head"><span class="order__id">#SP0988</span><span class="order__pill">Delivered · Dec 20, 2025</span></div>
              <div class="order__items">
                <div class="order__line"><div class="order__thumb" style="background:#f7d24c; color:#1b2a3a;">VERT</div><div><strong>Sun Punk Vertical Tee</strong><div class="order__meta">Navy · Size L · Qty 1</div></div><span>$20.00</span></div>
                <div class="order__line"><div class="order__thumb" style="background:#e8552c;">USA</div><div><strong>Sun Punk USA Koozie</strong><div class="order__meta">One size · Qty 1</div></div><span>$4.99</span></div>
              </div>
              <div class="order__total"><span>Total</span><span>$24.99</span></div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Account — main", "settings": [] }
{% endschema %}
