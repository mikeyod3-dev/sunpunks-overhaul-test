<footer class="site-footer" id="shopify-section-{{ section.id }}">
  <div class="container">
    <div class="site-footer__grid">
      <div>
        <p class="site-footer__brand">{{ section.settings.brand_text_left }}<span style="color:var(--sunset)">·</span>{{ section.settings.brand_text_right }}</p>
        <p style="max-width: 32ch; color:#ffffffaa; margin-top: .5rem;">{{ section.settings.tagline }}</p>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu_column' -%}
          <div {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading }}</h4>
            <ul class="stack">
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- elsif block.type == 'social' -%}
          <div {{ block.shopify_attributes }}>
            <h4>{{ block.settings.heading | default: 'Follow' }}</h4>
            <ul class="stack">
              {%- if settings.social_instagram != blank -%}<li><a href="{{ settings.social_instagram }}">Instagram</a></li>{%- endif -%}
              {%- if settings.social_tiktok != blank -%}<li><a href="{{ settings.social_tiktok }}">TikTok</a></li>{%- endif -%}
              {%- if settings.social_youtube != blank -%}<li><a href="{{ settings.social_youtube }}">YouTube</a></li>{%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__legal">
      <span>© <span data-year>{{ 'now' | date: '%Y' }}</span> {{ shop.name }} · <a href="{{ shop.privacy_policy.url | default: '#' }}">Privacy</a> · <a href="{{ shop.terms_of_service.url | default: '#' }}">Terms</a></span>
      <div class="payment-icons" aria-label="Accepted payment methods">
        {%- for type in shop.enabled_payment_types -%}
          <span>{{ type | replace: '_', ' ' | capitalize }}</span>
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "settings": [
    { "type": "text",     "id": "brand_text_left",  "label": "Brand text — left",  "default": "Sun" },
    { "type": "text",     "id": "brand_text_right", "label": "Brand text — right", "default": "Punks" },
    { "type": "textarea", "id": "tagline",          "label": "Tagline",            "default": "Surf. Sun. Soul." }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    },
    { "type": "social", "name": "Social column", "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Follow" } ] }
  ],
  "default": {
    "blocks": [
      { "type": "menu_column", "settings": { "heading": "Shop" } },
      { "type": "menu_column", "settings": { "heading": "Help" } },
      { "type": "social",      "settings": { "heading": "Follow" } }
    ]
  }
}
{% endschema %}
